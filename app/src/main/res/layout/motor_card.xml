<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="#0F1A2E"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center">

        <!-- Motor Icon -->
        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="#00D9A3"
            android:layout_marginBottom="10dp" />

        <!-- Motor Label -->
        <TextView
            android:id="@+id/motorLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Motor 1"
            android:textColor="#8E9AAF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <!-- Motor Percentage -->
        <TextView
            android:id="@+id/motorPercentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/motorProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:progress="50"
            android:max="100"
            android:progressTint="#00D9A3"
            android:progressBackgroundTint="#2A3F5F"
            android:indeterminate="false" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
