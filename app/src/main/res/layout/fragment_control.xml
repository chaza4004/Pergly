<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Current Command Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#162033"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Command"
                    android:textColor="#8E9AAF"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/currentCommandText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NONE"
                    android:textColor="#00D9A3"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Manual Controls Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#162033"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manual Controls"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp" />

                <!-- UP and DOWN Buttons Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <!-- UP Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/upBtn"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="UP"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#00D9A3"
                        app:icon="@android:drawable/arrow_up_float"
                        app:iconGravity="top"
                        app:iconSize="48dp"
                        app:iconTint="#FFFFFF"
                        android:paddingTop="20dp"
                        android:paddingBottom="20dp" />

                    <!-- DOWN Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/downBtn"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="DOWN"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#5B8DEF"
                        app:icon="@android:drawable/arrow_down_float"
                        app:iconGravity="top"
                        app:iconSize="48dp"
                        app:iconTint="#FFFFFF"
                        android:paddingTop="20dp"
                        android:paddingBottom="20dp" />
                </LinearLayout>

                <!-- Emergency Stop Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/emergencyStopBtn"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:text="EMERGENCY STOP"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="35dp"
                    app:backgroundTint="#FF5252"
                    app:icon="@android:drawable/ic_delete"
                    app:iconGravity="textStart"
                    app:iconSize="28dp"
                    app:iconTint="#FFFFFF"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A2640"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_dialog_info"
                    app:tint="#5B8DEF"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:id="@+id/infoText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="In AUTO mode, the pergola follows the sun automatically using light sensors. Switch to MANUAL mode for direct control."
                    android:textColor="#8E9AAF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>