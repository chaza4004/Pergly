<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/splash_gradient"
    android:padding="32dp">

    <!-- Solar Panel Icon/Logo -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:cardBackgroundColor="#00D9A3"
        app:cardCornerRadius="60dp"
        app:cardElevation="12dp"
        android:layout_marginBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/splashLogo"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@android:drawable/ic_menu_compass"
                app:tint="#FFFFFF"
                android:contentDescription="Pergly Logo" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- App Title -->
    <TextView
        android:id="@+id/splashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PERGLY"
        android:textColor="#FFFFFF"
        android:textSize="42sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:layout_marginBottom="8dp" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/splashSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Smart Solar Pergola"
        android:textColor="#8E9AAF"
        android:textSize="18sp"
        android:layout_marginBottom="48dp" />

    <!-- Loading Indicator -->
    <ProgressBar
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:indeterminateTint="#00D9A3"
        android:layout_marginTop="32dp" />

    <!-- Version/Footer Text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Powered by IoT Technology"
        android:textColor="#5A6B82"
        android:textSize="12sp"
        android:layout_marginTop="64dp" />

</LinearLayout>
